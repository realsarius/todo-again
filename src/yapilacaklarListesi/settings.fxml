<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="settingsRoot" prefHeight="480.0" prefWidth="560.0" styleClass="settings-root"
      xmlns="http://javafx.com/javafx/8.0.282-ea" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="yapilacaklarListesi.SettingsController">
    <HBox alignment="CENTER_LEFT" styleClass="settings-header">
        <Label styleClass="settings-title" text="Ayarlar"/>
    </HBox>

    <HBox styleClass="settings-body" VBox.vgrow="ALWAYS">
        <VBox prefWidth="120.0" minWidth="120.0" maxWidth="120.0" styleClass="settings-sidebar">
            <Button fx:id="gorunumKategoriButton" mnemonicParsing="false" onAction="#gorunumuGoster"
                    styleClass="settings-category-button" text="Görünüm"/>
            <Button fx:id="pomodoroKategoriButton" mnemonicParsing="false" onAction="#pomodoroyuGoster"
                    styleClass="settings-category-button" text="Pomodoro"/>
            <Button fx:id="bildirimlerKategoriButton" mnemonicParsing="false" onAction="#bildirimleriGoster"
                    styleClass="settings-category-button" text="Bildirimler"/>
            <Button fx:id="veriKategoriButton" mnemonicParsing="false" onAction="#veriyiGoster"
                    styleClass="settings-category-button" text="Veri"/>
            <Button fx:id="guncellemelerKategoriButton" mnemonicParsing="false" onAction="#guncellemeleriGoster"
                    styleClass="settings-category-button" text="Güncellemeler"/>
        </VBox>

        <StackPane styleClass="settings-content" HBox.hgrow="ALWAYS">
            <VBox fx:id="gorunumSection" spacing="12.0" styleClass="settings-section">
                <Label styleClass="settings-section-title" text="Görünüm"/>
                <HBox alignment="CENTER_LEFT" styleClass="settings-row">
                    <Label minWidth="140.0" prefWidth="140.0" styleClass="settings-row-label" text="Tema"/>
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <RadioButton fx:id="temaAcikRadio" mnemonicParsing="false" styleClass="settings-segment-option" text="Açık"/>
                        <RadioButton fx:id="temaKoyuRadio" mnemonicParsing="false" styleClass="settings-segment-option" text="Koyu"/>
                        <RadioButton fx:id="temaSistemRadio" mnemonicParsing="false" styleClass="settings-segment-option" text="Sistem"/>
                    </HBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" styleClass="settings-row">
                    <Label minWidth="140.0" prefWidth="140.0" styleClass="settings-row-label" text="Dil"/>
                    <ComboBox fx:id="dilComboBox" prefWidth="180.0" styleClass="settings-combo"/>
                </HBox>
            </VBox>
            <VBox fx:id="pomodoroSection" spacing="12.0" styleClass="settings-section" visible="false" managed="false">
                <Label styleClass="settings-section-title" text="Pomodoro"/>
                <HBox alignment="CENTER_LEFT" styleClass="settings-row">
                    <Label minWidth="140.0" prefWidth="140.0" styleClass="settings-row-label" text="Çalışma süresi"/>
                    <Spinner fx:id="pomodoroCalismaSpinner" prefWidth="100.0" styleClass="settings-spinner"/>
                    <Label styleClass="settings-row-desc" text="dakika"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" styleClass="settings-row">
                    <Label minWidth="140.0" prefWidth="140.0" styleClass="settings-row-label" text="Kısa mola"/>
                    <Spinner fx:id="pomodoroKisaMolaSpinner" prefWidth="100.0" styleClass="settings-spinner"/>
                    <Label styleClass="settings-row-desc" text="dakika"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" styleClass="settings-row">
                    <Label minWidth="140.0" prefWidth="140.0" styleClass="settings-row-label" text="Uzun mola"/>
                    <Spinner fx:id="pomodoroUzunMolaSpinner" prefWidth="100.0" styleClass="settings-spinner"/>
                    <Label styleClass="settings-row-desc" text="dakika"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" styleClass="settings-row">
                    <Label minWidth="140.0" prefWidth="140.0" styleClass="settings-row-label" text="Uzun mola aralığı"/>
                    <Spinner fx:id="pomodoroUzunMolaAraligiSpinner" prefWidth="100.0" styleClass="settings-spinner"/>
                    <Label styleClass="settings-row-desc" text="pomodoro"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" styleClass="settings-row">
                    <Label minWidth="140.0" prefWidth="140.0" styleClass="settings-row-label" text="Ses bildirimi"/>
                    <CheckBox fx:id="pomodoroSesBildirimCheckBox" mnemonicParsing="false" styleClass="settings-checkbox" text="Açık"/>
                </HBox>
            </VBox>
            <VBox fx:id="bildirimlerSection" spacing="12.0" styleClass="settings-section" visible="false" managed="false">
                <Label styleClass="settings-section-title" text="Bildirimler"/>
                <HBox alignment="CENTER_LEFT" styleClass="settings-row">
                    <Label minWidth="140.0" prefWidth="140.0" styleClass="settings-row-label" text="Masaüstü bildirimi"/>
                    <CheckBox fx:id="bildirimMasaustuCheckBox" mnemonicParsing="false" styleClass="settings-checkbox" text="Açık"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" styleClass="settings-row">
                    <Label minWidth="140.0" prefWidth="140.0" styleClass="settings-row-label" text="Görev hatırlatıcısı"/>
                    <CheckBox fx:id="gorevHatirlaticisiCheckBox" mnemonicParsing="false" styleClass="settings-checkbox" text="Açık"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" styleClass="settings-row">
                    <Label minWidth="140.0" prefWidth="140.0" styleClass="settings-row-label" text="Bildirim sesi"/>
                    <CheckBox fx:id="bildirimSesiCheckBox" mnemonicParsing="false" styleClass="settings-checkbox" text="Açık"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" styleClass="settings-row">
                    <Label minWidth="140.0" prefWidth="140.0" styleClass="settings-row-label" text="Sessiz saatler"/>
                    <CheckBox fx:id="sessizSaatlerCheckBox" mnemonicParsing="false" styleClass="settings-checkbox" text="Etkin"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" styleClass="settings-row">
                    <Label minWidth="140.0" prefWidth="140.0" styleClass="settings-row-label" text="Başlangıç / Bitiş"/>
                    <HBox alignment="CENTER_LEFT" spacing="6.0">
                        <Spinner fx:id="sessizSaatBaslangicSaatSpinner" prefWidth="72.0" styleClass="settings-spinner"/>
                        <Label styleClass="settings-row-desc" text=":"/>
                        <Spinner fx:id="sessizSaatBaslangicDakikaSpinner" prefWidth="72.0" styleClass="settings-spinner"/>
                        <Label styleClass="settings-row-desc" text="—"/>
                        <Spinner fx:id="sessizSaatBitisSaatSpinner" prefWidth="72.0" styleClass="settings-spinner"/>
                        <Label styleClass="settings-row-desc" text=":"/>
                        <Spinner fx:id="sessizSaatBitisDakikaSpinner" prefWidth="72.0" styleClass="settings-spinner"/>
                    </HBox>
                </HBox>
            </VBox>
            <VBox fx:id="veriSection" spacing="12.0" styleClass="settings-section" visible="false" managed="false">
                <Label styleClass="settings-section-title" text="Veri"/>
                <HBox alignment="CENTER_LEFT" styleClass="settings-row" spacing="8.0">
                    <Label minWidth="140.0" prefWidth="140.0" styleClass="settings-row-label" text="JSON dışa aktar"/>
                    <Button fx:id="veriDisaAktarButton" mnemonicParsing="false" styleClass="settings-secondary-button" text="Dışa Aktar"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" styleClass="settings-row" spacing="8.0">
                    <Label minWidth="140.0" prefWidth="140.0" styleClass="settings-row-label" text="Yedekten geri yükle"/>
                    <Button fx:id="veriIceAktarButton" mnemonicParsing="false" styleClass="settings-secondary-button" text="İçe Aktar"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" styleClass="settings-row">
                    <Label minWidth="140.0" prefWidth="140.0" styleClass="settings-row-label" text="Otomatik yedekleme"/>
                    <CheckBox fx:id="otomatikYedeklemeCheckBox" mnemonicParsing="false" styleClass="settings-checkbox" text="Açık"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" styleClass="settings-row">
                    <Label minWidth="140.0" prefWidth="140.0" styleClass="settings-row-label" text="Yedek aralığı"/>
                    <ComboBox fx:id="otomatikYedeklemeAralikComboBox" prefWidth="180.0" styleClass="settings-combo"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" styleClass="settings-row" spacing="8.0">
                    <Label minWidth="140.0" prefWidth="140.0" styleClass="settings-row-label" text="Tüm verileri sıfırla"/>
                    <Button fx:id="veriSifirlaButton" mnemonicParsing="false" styleClass="settings-danger-button" text="Sıfırla"/>
                </HBox>
            </VBox>
            <VBox fx:id="guncellemelerSection" spacing="12.0" styleClass="settings-section" visible="false" managed="false">
                <Label styleClass="settings-section-title" text="Güncellemeler"/>
                <HBox alignment="CENTER_LEFT" styleClass="settings-row">
                    <Label minWidth="140.0" prefWidth="140.0" styleClass="settings-row-label" text="Mevcut sürüm"/>
                    <Label fx:id="mevcutSurumValueLabel" styleClass="settings-row-value" text="-"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" styleClass="settings-row" spacing="8.0">
                    <Label minWidth="140.0" prefWidth="140.0" styleClass="settings-row-label" text="Kontrol"/>
                    <Button fx:id="guncellemeleriKontrolEtButton" mnemonicParsing="false" styleClass="settings-secondary-button" text="Güncellemeleri Kontrol Et"/>
                    <Hyperlink fx:id="guncellemeIndirLinki" text="İndir"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" styleClass="settings-row">
                    <Label minWidth="140.0" prefWidth="140.0" styleClass="settings-row-label" text="Durum"/>
                    <Label fx:id="guncellemeDurumLabel" styleClass="settings-row-desc settings-status-info" text="Henüz kontrol edilmedi." wrapText="true"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" styleClass="settings-row">
                    <Label minWidth="140.0" prefWidth="140.0" styleClass="settings-row-label" text="Otomatik kontrol"/>
                    <CheckBox fx:id="guncellemeOtomatikKontrolCheckBox" mnemonicParsing="false" styleClass="settings-checkbox" text="Açık"/>
                </HBox>
            </VBox>
        </StackPane>
    </HBox>

    <HBox alignment="CENTER_RIGHT" spacing="8.0" styleClass="settings-footer">
        <Pane HBox.hgrow="ALWAYS"/>
        <Button fx:id="iptalButton" mnemonicParsing="false" onAction="#iptalEt" styleClass="settings-secondary-button" text="İptal"/>
        <Button fx:id="kaydetButton" mnemonicParsing="false" onAction="#kaydetVeKapat" styleClass="settings-primary-button" text="Kaydet"/>
    </HBox>
</VBox>
